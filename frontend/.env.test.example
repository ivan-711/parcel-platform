# Playwright E2E test environment
# Copy this file to .env.test and fill in real values.
# .env.test is gitignored — never commit it.

# Point frontend + tests at local backend (where dev-only
# testing endpoints are registered)
VITE_API_URL=http://localhost:8000

# Dev Clerk instance keys (NOT production pk_live keys)
# Get from: dashboard.clerk.com → your dev instance → API keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Clerk dev-instance test user credentials
# Create at: dashboard.clerk.com → Users → + New user
# Requires password auth enabled on the dev instance
E2E_CLERK_USER_USERNAME=e2e-test@parceldesk.io
E2E_CLERK_USER_PASSWORD=REPLACE_ME
