# API backend URL — defaults to https://api.parceldesk.io if unset
VITE_API_URL=http://localhost:8000

# Clerk authentication — get from Clerk dashboard > API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Google Maps Places API — used for address autocomplete
VITE_GOOGLE_PLACES_API_KEY=your_google_places_key

# PostHog analytics — get project API key from PostHog dashboard
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# DO NOT set VITE_DEV_PREVIEW in production — enables mock API mode
# VITE_DEV_PREVIEW=true
