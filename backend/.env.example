DATABASE_URL=postgresql://user:password@localhost/parcel
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
SECRET_KEY=generate-a-random-32-char-string-here
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# Monitoring (optional — app runs fine without these)
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=

# File storage — set S3_ENDPOINT_URL for Cloudflare R2 (e.g. https://<account>.r2.cloudflarestorage.com)
S3_ENDPOINT_URL=

# Stripe billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PLUS_MONTHLY=price_...
STRIPE_PRICE_PLUS_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...

# Background jobs (Railway Redis add-on)
REDIS_URL=

# Clerk auth (dual-mode — app works without these using legacy JWT)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Report analytics — salt for IP address hashing (generate a random string)
IP_HASH_SALT=generate-a-random-salt-here

# Property data providers
RENTCAST_API_KEY=
RENTCAST_BASE_URL=https://api.rentcast.io/v1
BRICKED_API_KEY=
BRICKED_BASE_URL=https://api.bricked.ai
NOMINATIM_USER_AGENT=parcel-platform/1.0

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_STATUS_CALLBACK_URL=

# SendGrid email
SENDGRID_API_KEY=
SENDGRID_WEBHOOK_VERIFICATION_KEY=
SENDGRID_WEBHOOK_SECRET=
DEFAULT_FROM_EMAIL=noreply@parceldesk.io

# Internal cron endpoints
INTERNAL_API_KEY=generate-a-random-key-here

# BatchData skip tracing
BATCHDATA_API_KEY=

# Lob direct mail
LOB_API_KEY=
LOB_ENV=test
